    "CC1": {
      "classification": "Hypervirulent",
      "lineage": "I",
      "serotypes": [
        "4b",
        "4d",
        "4e"
      ],
      "clinical_significance": "HIGH",
      "clinical_frequency": "Very common in human listeriosis",
      "notes": "Hypervirulent clone responsible for majority of human listeriosis cases. Associated with CNS and maternal-neonatal infections. Maury et al. 2016 (Nature Genetics).",
