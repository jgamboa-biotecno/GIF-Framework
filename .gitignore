# GIF Framework — .gitignore

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Packaging and distribution
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.env
.venv/
venv/
env/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# CLI runtime temporaries
/tmp/
*.log
gif_cli_tmp_*/

# Downloaded genomic data (large, not versioned)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam
*.sra

# Runtime output (user-generated, not part of the repo)
results/
output/

# Databases downloaded at runtime (packaged reference data IS committed)
gif/db/downloaded/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Coverage and testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Jupyter
.ipynb_checkpoints/
